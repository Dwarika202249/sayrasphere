# SayraSphere Server - Production Environment Template
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/sayrasphere
JWT_SECRET=your_strong_jwt_secret_here
JWT_REFRESH_SECRET=your_strong_refresh_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI Service (Groq)
GROQ_API_KEY=your_groq_api_key

# MQTT (HiveMQ Cloud)
MQTT_BROKER=wss://<endpoint>.hivemq.cloud:8884/mqtt
MQTT_USER=your_hivemq_user
MQTT_PASS=your_hivemq_password

# Frontend URL (for CORS and OAuth Redirects)
CLIENT_URL=https://your-app.vercel.app

# Optional: Dedicated account for Showcase Mode
DEMO_USER=test@sayrasphere.com
