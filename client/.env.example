# SayraSphere Client - Production Environment Template
# Note: VITE_ variables are embedded at build time

# Production API URL (Render/Railway address)
VITE_API_URL=https://your-server.onrender.com

# Socket.IO URL (Usually same as API URL)
VITE_SOCKET_URL=https://your-server.onrender.com

# Optional: Dedicated account for Showcase Mode
VITE_DEMO_USER=test@sayrasphere.com
